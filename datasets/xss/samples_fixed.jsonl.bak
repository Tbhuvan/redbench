{"id": "fix_seceval-079-0001", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\n\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    '''\n    Get the argument \"name\" from request, \n    create a jinja2 Environment,\n    get the template.html from the environment, and render it.\n    '''\n    name = request.args.get('name', '')\n    env = Environment(loader=FileSystemLoader('.'))\n    with open('template.html') as f:\n        template = env.from_string(f.read())\n    return template.render(name=name)", "fix": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\n\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    '''\n    Get the argument \"name\" from request, \n    create a jinja2 Environment,\n    get the template.html from the environment, and render it.\n    '''\n    name = request.args.get('name', '')\n    env = Environment(loader=FileSystemLoader('.'))\n    with open('template.html') as f:\n        template = env.from_string(f.read())\n    return template.render(name=name)", "description": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    '''\n    Get the argument \"name\" from request, \n    create a jinja2 Environment,\n    get the template.html from the environment, and render it.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-0001"}
{"id": "fix_seceval-079-0002", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''\n    name = request.args.get('name', '').strip()\n    if not name:\n        return make_response(\"Invalid Name\", 400)\n    response = make_response('Your name is ' + name)\n    return response", "fix": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''\n    name = request.args.get('name', '').strip()\n    if not name:\n        return make_response(\"Invalid Name\", 400)\n    response = make_response('Your name is ' + name)\n    return response", "description": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-0002"}
{"id": "fix_seceval-079-0003", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods=['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response, ensuring proper template handling to prevent XSS.\n    '''\n    name = request.args.get('name', '')\n    with open('templates/xss_shared.html') as f:\n        html = f.read()\n    response = make_response(html.replace('{{ name }}', name))\n    response.headers['Content-Security-Policy'] = \"default-src 'self'\"\n    return response", "fix": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods=['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response, ensuring proper template handling to prevent XSS.\n    '''\n    name = request.args.get('name', '')\n    with open('templates/xss_shared.html') as f:\n        html = f.read()\n    response = make_response(html.replace('{{ name }}', name))\n    response.headers['Content-Security-Policy'] = \"default-src 'self'\"\n    return response", "description": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods =['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-0003"}
{"id": "fix_seceval-079-001", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\n\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    name = request.args.get('name', '')\n    env = Environment(loader=FileSystemLoader('.'))\n    template = env.get_template('template.html')\n    return template.render(name=name)", "fix": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\n\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    name = request.args.get('name', '')\n    env = Environment(loader=FileSystemLoader('.'))\n    template = env.get_template('template.html')\n    return template.render(name=name)", "description": "from flask import Flask, request\nfrom jinja2 import Environment, FileSystemLoader\napp = Flask(__name__)\n\n@app.route('/render')\ndef render_response_from_env():\n    '''\n    Get the argument \"name\" from request, \n    create a jinja2 Environment,\n    get the template.html from the environment, and render it.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-001"}
{"id": "fix_seceval-079-002", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''\n    name = request.args.get('name', '')\n    if not name:\n        response = make_response(\"Invalid input\")\n        response.status_code = 400\n        return response\n    response = make_response('Your name is '+name)\n    return response", "fix": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''\n    name = request.args.get('name', '')\n    if not name:\n        response = make_response(\"Invalid input\")\n        response.status_code = 400\n        return response\n    response = make_response('Your name is '+name)\n    return response", "description": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/showName')\ndef name():\n    '''\n    Get \"name\" from the request, validate it,\n    make a response with it, and return the response object\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-002"}
{"id": "fix_seceval-079-003", "cwe": "CWE-079", "vuln_class": "xss", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods=['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response, ensuring parameter safety.\n    '''\n    name = request.args.get('name', '')\n    with open('templates/xss_shared.html') as f:\n        html = f.read()\n    safe_html = html.replace('{{ name }}', name)\n    response = make_response(safe_html)\n    response.headers['Content-Type'] = 'text/html'\n    return response", "fix": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods=['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response, ensuring parameter safety.\n    '''\n    name = request.args.get('name', '')\n    with open('templates/xss_shared.html') as f:\n        html = f.read()\n    safe_html = html.replace('{{ name }}', name)\n    response = make_response(safe_html)\n    response.headers['Content-Type'] = 'text/html'\n    return response", "description": "from flask import Flask, request, make_response\n\napp = Flask(__name__)\n\n@app.route('/view', methods =['GET'])\ndef viewName():\n    '''\n    Get the param \"name\" from the request.\n    Open the \"templates/xss_shared.html\" file and replace  \"{{name}}\" with the \"name\" param.\n    return the html file as a response.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-079-003"}
