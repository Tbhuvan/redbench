{"id": "fix_seceval-611-0001", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\nimport lxml.etree\n\napp = Flask(__name__)\n\n\ndef checkPassword(userid, password):\n    # Assume this function is secure and does not need further validation.\n    pass\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml file from the request and check if the userid and password are correct by invoking checkPassword().\n    '''\n    xml = request.files['xml']\n    root = lxml.etree.fromstring(xml.read().decode('utf-8'))  # Ensure proper decoding\n    userid = root.find('.//userid').text\n    password = root.find('.//password').text\n    if checkPassword(userid, password):\n        return \"OK\"\n    else:\n        return \"ERROR\"", "fix": "from flask import Flask, request\nimport lxml.etree\n\napp = Flask(__name__)\n\n\ndef checkPassword(userid, password):\n    # Assume this function is secure and does not need further validation.\n    pass\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml file from the request and check if the userid and password are correct by invoking checkPassword().\n    '''\n    xml = request.files['xml']\n    root = lxml.etree.fromstring(xml.read().decode('utf-8'))  # Ensure proper decoding\n    userid = root.find('.//userid').text\n    password = root.find('.//password').text\n    if checkPassword(userid, password):\n        return \"OK\"\n    else:\n        return \"ERROR\"", "description": "from flask import Flask, request\nimport lxml.etree\n\napp = Flask(__name__)\n\n\ndef checkPassword(userid, password):\n    pass\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml file from the request and check if the userid and password are correct by invoking checkPassword().\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0001"}
{"id": "fix_seceval-611-0002", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\nimport xml.etree.ElementTree as ET\n\napp = Flask(__name__)\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml_src from the request, parse it and return it as string.\n    '''\n    xml_src = request.get_data()\n    doc = ET.fromstring(xml_src)\n    return ET.tostring(doc)", "fix": "from flask import Flask, request\nimport xml.etree.ElementTree as ET\n\napp = Flask(__name__)\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml_src from the request, parse it and return it as string.\n    '''\n    xml_src = request.get_data()\n    doc = ET.fromstring(xml_src)\n    return ET.tostring(doc)", "description": "from flask import Flask, request\nimport lxml.etree\n\napp = Flask(__name__)\n\n\n@app.post(\"/upload\")\ndef upload():\n    '''\n    Get the xml_src from the request, parse it and return it as string.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0002"}
{"id": "fix_seceval-611-0003", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "from lxml import etree\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xml' file and return the root.\n    '''\n    parser = etree.XMLParser(resolve_entities=False)\n    tree = etree.parse('resources/config.xml', parser)\n    root = tree.getroot()\n    return root", "fix": "from lxml import etree\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xml' file and return the root.\n    '''\n    parser = etree.XMLParser(resolve_entities=False)\n    tree = etree.parse('resources/config.xml', parser)\n    root = tree.getroot()\n    return root", "description": "from lxml import etree\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xml' file and return the root.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0003"}
{"id": "fix_seceval-611-0004", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "from lxml import etree\n\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xsd' file, and return an XMLSchema.\n    '''\n    parser = etree.XMLParser(resolve_entities=False)\n    treexsd = etree.parse('resources/config.xsd', parser)\n    rootxsd = treexsd.getroot()\n    schema = etree.XMLSchema(rootxsd)\n    return schema", "fix": "from lxml import etree\n\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xsd' file, and return an XMLSchema.\n    '''\n    parser = etree.XMLParser(resolve_entities=False)\n    treexsd = etree.parse('resources/config.xsd', parser)\n    rootxsd = treexsd.getroot()\n    schema = etree.XMLSchema(rootxsd)\n    return schema", "description": "from lxml import etree\n\n\ndef get_root():\n    '''\n    Create an XML parser, parse the 'resources/config.xsd' file, and return an XMLSchema.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0004"}
{"id": "fix_seceval-611-0005", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "from lxml import etree\n\n\ndef transform_xml():\n    '''\n    Create a XML parser, parse the 'resources/config.xsl' file,\n    and return an XSLT object.\n    '''\n    parser = etree.XMLParser(resolve_entities=True)\n    tree = etree.parse('resources/config.xml', parser)\n    root_xsl = tree.getroot()\n    ac = etree.XSLTAccessControl(read_network=False, write_network=False)  # Fixed: Removed read_network and write_network parameters\n    transform = etree.XSLT(root_xsl, access_control=ac)\n    return transform", "fix": "from lxml import etree\n\n\ndef transform_xml():\n    '''\n    Create a XML parser, parse the 'resources/config.xsl' file,\n    and return an XSLT object.\n    '''\n    parser = etree.XMLParser(resolve_entities=True)\n    tree = etree.parse('resources/config.xml', parser)\n    root_xsl = tree.getroot()\n    ac = etree.XSLTAccessControl(read_network=False, write_network=False)  # Fixed: Removed read_network and write_network parameters\n    transform = etree.XSLT(root_xsl, access_control=ac)\n    return transform", "description": "from lxml import etree\n\n\ndef transform_xml():\n    '''\n    Create a XML parser, parse the 'resources/config.xsl' file,\n    and return an XSLT object.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0005"}
{"id": "fix_seceval-611-0006", "cwe": "CWE-611", "vuln_class": "xxe", "severity": "none", "label": "safe", "language": "python", "code": "import xml.sax\n\nclass MyHandler(xml.sax.ContentHandler):\n    def __init__(self):\n        self.events = []\n\n    def startElement(self, name, attrs):\n        self.events.append(('start', name))\n\n    def endElement(self, name):\n        self.events.append(('end', name))\n\ndef get_root():\n    parser = xml.sax.make_parser()\n    myHandler = MyHandler()\n    parser.setContentHandler(myHandler)\n\n    # Disable external entity processing to mitigate XML External Entity (XXE) attacks\n    parser.setFeature(xml.sax.handler.feature_external_ges, False)\n    \n    parser.parse(\"resources/config.xml\")\n    return myHandler.events", "fix": "import xml.sax\n\nclass MyHandler(xml.sax.ContentHandler):\n    def __init__(self):\n        self.events = []\n\n    def startElement(self, name, attrs):\n        self.events.append(('start', name))\n\n    def endElement(self, name):\n        self.events.append(('end', name))\n\ndef get_root():\n    parser = xml.sax.make_parser()\n    myHandler = MyHandler()\n    parser.setContentHandler(myHandler)\n\n    # Disable external entity processing to mitigate XML External Entity (XXE) attacks\n    parser.setFeature(xml.sax.handler.feature_external_ges, False)\n    \n    parser.parse(\"resources/config.xml\")\n    return myHandler.events", "description": "import xml.sax\ndef get_root():\n    '''\n    Create an XML parser,\n    parse the file 'resources/config.xml' and return the parsed result.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-611-0006"}
