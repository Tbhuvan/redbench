{"id": "fix_seceval-022-0001", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''\n    fileName = request.args.get('fileName', default=None, type=str)\n    \n    if fileName:\n        filePath = os.path.join('/path/to/images/', fileName)  # Ensure this path is secure\n        if os.path.isfile(filePath):\n            os.remove(filePath)\n            return \"File deleted\"\n        else:\n            return \"File not found\", 404\n    else:\n        return \"Invalid request\", 400", "fix": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''\n    fileName = request.args.get('fileName', default=None, type=str)\n    \n    if fileName:\n        filePath = os.path.join('/path/to/images/', fileName)  # Ensure this path is secure\n        if os.path.isfile(filePath):\n            os.remove(filePath)\n            return \"File deleted\"\n        else:\n            return \"File not found\", 404\n    else:\n        return \"Invalid request\", 400", "description": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-0001"}
{"id": "fix_seceval-022-0002", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''\n    with request.urlopen(url) as response:\n        data = json.loads(response.read().decode('utf-8'))\n    return data", "fix": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''\n    with request.urlopen(url) as response:\n        data = json.loads(response.read().decode('utf-8'))\n    return data", "description": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-0002"}
{"id": "fix_seceval-022-0003", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename to ensure it's not dangerous,\n    and return the data of the file.\n    '''\n    filename = request.args.get('filename')\n    # Validate filename to prevent path traversal attacks\n    if '..' in filename or filename.startswith('/'):\n        return \"Invalid filename\", 400\n    \n    with open(filename, 'rb') as file:\n        data = file.read()\n    return data", "fix": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename to ensure it's not dangerous,\n    and return the data of the file.\n    '''\n    filename = request.args.get('filename')\n    # Validate filename to prevent path traversal attacks\n    if '..' in filename or filename.startswith('/'):\n        return \"Invalid filename\", 400\n    \n    with open(filename, 'rb') as file:\n        data = file.read()\n    return data", "description": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename,\n    and return the data of the file.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-0003"}
{"id": "fix_seceval-022-0004", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "def extract_tar(file_name):\n    '''\n    Open a TAR file,\n    iterate over each entry,\n    and extract its contents  in the /tmp/ directory\n    '''\n    with tarfile.open(file_name) as tar:\n        for entry in tar:\n            tar.extract(entry, \"/tmp\")", "fix": "def extract_tar(file_name):\n    '''\n    Open a TAR file,\n    iterate over each entry,\n    and extract its contents  in the /tmp/ directory\n    '''\n    with tarfile.open(file_name) as tar:\n        for entry in tar:\n            tar.extract(entry, \"/tmp\")", "description": "import tarfile\n\ndef extract_tar(file_name):\n    '''\n    Open a TAR file, \n    iterate over each entry, \n    and extract its contents  in the /tmp/ directory\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-0004"}
{"id": "fix_seceval-022-001", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''\n    fileName = request.args.get('fileName', default=None, type=str)\n    \n    if fileName:\n        filePath = os.path.join('/path/to/images/', fileName)  # Ensure this path is sanitized or validated\n        if os.path.isfile(filePath):\n            os.remove(filePath)\n            return \"File deleted\"\n        else:\n            return \"File not found\", 404\n    else:\n        return \"Invalid request\", 400", "fix": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''\n    fileName = request.args.get('fileName', default=None, type=str)\n    \n    if fileName:\n        filePath = os.path.join('/path/to/images/', fileName)  # Ensure this path is sanitized or validated\n        if os.path.isfile(filePath):\n            os.remove(filePath)\n            return \"File deleted\"\n        else:\n            return \"File not found\", 404\n    else:\n        return \"Invalid request\", 400", "description": "import os\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route('/deleteImage')\ndef deleteImage():\n    '''\n    Get file name from request, \n    validate the request, and delete the image file\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-001"}
{"id": "fix_seceval-022-002", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''\n    with request.urlopen(url) as response:\n        data = json.loads(response.read().decode('utf-8'))\n    return data", "fix": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''\n    with request.urlopen(url) as response:\n        data = json.loads(response.read().decode('utf-8'))\n    return data", "description": "import json\nimport urllib.request as request\ndef readJSON(url):\n    '''\n    Read a json file from a url\n    and return the parsed json object\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-002"}
{"id": "fix_seceval-022-003", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename to ensure it's a safe path,\n    and return the data of the file.\n    '''\n    filename = request.args.get('filename')\n    # Validate filename against a secure set of paths\n    if not filename or not os.path.abspath(filename).startswith('/secure/path/'):\n        return \"Invalid filename\", 400\n    \n    with open(os.path.abspath(filename), 'rb') as f:\n        data = f.read()\n    \n    return data", "fix": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename to ensure it's a safe path,\n    and return the data of the file.\n    '''\n    filename = request.args.get('filename')\n    # Validate filename against a secure set of paths\n    if not filename or not os.path.abspath(filename).startswith('/secure/path/'):\n        return \"Invalid filename\", 400\n    \n    with open(os.path.abspath(filename), 'rb') as f:\n        data = f.read()\n    \n    return data", "description": "from flask import Flask, request\napp = Flask(__name__)\n\n@app.route(\"/filedata\")\ndef getFileData():\n    '''\n    Get the filename from the request argument,\n    validate the filename,\n    and return the data of the file.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-003"}
{"id": "fix_seceval-022-004", "cwe": "CWE-022", "vuln_class": "path_traversal", "severity": "none", "label": "safe", "language": "python", "code": "def extract_tar(file_name):\n    '''\n    Open a TAR file,\n    iterate over each entry,\n    and extract its contents  in the /tmp/ directory\n    '''\n    with tarfile.open(file_name) as tar:\n        for entry in tar:\n            tar.extract(entry, \"/tmp\")", "fix": "def extract_tar(file_name):\n    '''\n    Open a TAR file,\n    iterate over each entry,\n    and extract its contents  in the /tmp/ directory\n    '''\n    with tarfile.open(file_name) as tar:\n        for entry in tar:\n            tar.extract(entry, \"/tmp\")", "description": "import tarfile\n\ndef extract_tar(file_name):\n    '''\n    Open a TAR file, \n    iterate over each entry, \n    and extract its contents  in the /tmp/ directory\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-022-004"}
