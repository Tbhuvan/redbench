{"id": "seceval-295-0001", "cwe": "CWE-295", "vuln_class": "tls_validation", "severity": "high", "label": "vulnerable", "language": "python", "code": "import ssl\n\n\ndef getSSLContext():\n    '''\n    Create an SSL context and return it.\n    '''\n    ctx = ssl.create_default_context()\n    ctx.check_hostname = False\n    ctx.verify_mode = ssl.CERT_NONE\n    return ctx", "description": "import ssl\n\n\ndef getSSLContext():\n    '''\n    Create an SSL context and return it.\n    '''", "fix": "", "source": "securityeval"}
{"id": "seceval-295-0002", "cwe": "CWE-295", "vuln_class": "tls_validation", "severity": "high", "label": "vulnerable", "language": "python", "code": "from OpenSSL import SSL\n\ndef getContext():\n    '''\n    Create an OpenSSL context and return it.\n    '''\n    ctx = SSL.Context(SSL.TLSv1_2_METHOD)\n    return ctx", "description": "from OpenSSL import SSL\n\ndef getContext():\n    '''\n    Create an OpenSSL context and return it.\n    '''", "fix": "", "source": "securityeval"}
