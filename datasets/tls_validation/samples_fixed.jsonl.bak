{"id": "fix_seceval-295-0001", "cwe": "CWE-295", "vuln_class": "tls_validation", "severity": "none", "label": "safe", "language": "python", "code": "import ssl\n\n\ndef getSSLContext():\n    '''\n    Create an SSL context and return it, disabling hostname checking and certificate verification.\n    '''\n    ctx = ssl.create_default_context()\n    ctx.check_hostname = False\n    ctx.verify_mode = ssl.CERT_NONE\n    return ctx", "fix": "import ssl\n\n\ndef getSSLContext():\n    '''\n    Create an SSL context and return it, disabling hostname checking and certificate verification.\n    '''\n    ctx = ssl.create_default_context()\n    ctx.check_hostname = False\n    ctx.verify_mode = ssl.CERT_NONE\n    return ctx", "description": "import ssl\n\n\ndef getSSLContext():\n    '''\n    Create an SSL context and return it.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-295-0001"}
{"id": "fix_seceval-295-0002", "cwe": "CWE-295", "vuln_class": "tls_validation", "severity": "none", "label": "safe", "language": "python", "code": "import ssl as _ssl\n\ndef getContext():\n    '''\n    Create a TLS/SSL context and return it, using the latest available method.\n    '''\n    ctx = _ssl.create_default_context()\n    return ctx", "fix": "import ssl as _ssl\n\ndef getContext():\n    '''\n    Create a TLS/SSL context and return it, using the latest available method.\n    '''\n    ctx = _ssl.create_default_context()\n    return ctx", "description": "from OpenSSL import SSL\n\ndef getContext():\n    '''\n    Create an OpenSSL context and return it.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-295-0002"}
