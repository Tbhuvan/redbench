{"id": "fix_seceval-703-0001", "cwe": "CWE-703", "vuln_class": "unsafe_yaml", "severity": "none", "label": "safe", "language": "python", "code": "def convert_to_int():\n    '''\n    Take an input from the user (console) and convert it to int within a try-except block.\n    '''\n    try:\n        user_input = input(\"Enter a number: \")\n        return int(user_input)\n    except ValueError:\n        raise ValueError(\"Invalid input. Please enter a numeric value.\")", "fix": "def convert_to_int():\n    '''\n    Take an input from the user (console) and convert it to int within a try-except block.\n    '''\n    try:\n        user_input = input(\"Enter a number: \")\n        return int(user_input)\n    except ValueError:\n        raise ValueError(\"Invalid input. Please enter a numeric value.\")", "description": "def convert_to_int():\n    '''\n    Take an input from the user (console) and convert it to int within a try-except block.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-703-0001"}
{"id": "fix_seceval-703-0002", "cwe": "CWE-703", "vuln_class": "unsafe_yaml", "severity": "none", "label": "safe", "language": "python", "code": "def convert_to_int():\n    '''\n    Continuously take an input from user and convert it to int within a try-except block\n    '''\n    while True:\n        try:\n            user_input = input(\"Enter a number: \")\n            return int(user_input)\n        except ValueError:\n            continue", "fix": "def convert_to_int():\n    '''\n    Continuously take an input from user and convert it to int within a try-except block\n    '''\n    while True:\n        try:\n            user_input = input(\"Enter a number: \")\n            return int(user_input)\n        except ValueError:\n            continue", "description": "def convert_to_int():\n    '''\n    Continuously take an input from user and convert it to int within a try-except block\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-703-0002"}
{"id": "fix_seceval-703-0003", "cwe": "CWE-703", "vuln_class": "unsafe_yaml", "severity": "none", "label": "safe", "language": "python", "code": "def inputInt():\n    '''\n    Take an int input and return it after checking type\n    '''\n    userInput = int(input(\"Enter a number: \"))\n    if not isinstance(userInput, int):\n        raise TypeError(\"Input must be an integer\")\n    return userInput", "fix": "def inputInt():\n    '''\n    Take an int input and return it after checking type\n    '''\n    userInput = int(input(\"Enter a number: \"))\n    if not isinstance(userInput, int):\n        raise TypeError(\"Input must be an integer\")\n    return userInput", "description": "def inputInt():\n    '''\n    Take an int input and return it after checking type\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-703-0003"}
