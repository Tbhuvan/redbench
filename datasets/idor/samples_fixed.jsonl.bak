{"id": "fix_ghsa-639-0002", "cwe": "CWE-639", "vuln_class": "idor", "severity": "none", "label": "safe", "language": "python", "code": "@router.delete(\"/{api_key_id}\", dependencies=[Depends(auth_utils.get_current_active_user)])\nasync def delete_api_key_route(\n    api_key_id: UUID,\n    db: DbSession,\n):\n    try:\n        await delete_api_key(db, api_key_id)\n    except Exception as e:\n        raise HTTPException(status_code=400, detail=str(e).strip(\"u\"))\n    return {\"detail\": \"API Key deleted\"}", "fix": "@router.delete(\"/{api_key_id}\", dependencies=[Depends(auth_utils.get_current_active_user)])\nasync def delete_api_key_route(\n    api_key_id: UUID,\n    db: DbSession,\n):\n    try:\n        await delete_api_key(db, api_key_id)\n    except Exception as e:\n        raise HTTPException(status_code=400, detail=str(e).strip(\"u\"))\n    return {\"detail\": \"API Key deleted\"}", "description": "GHSA-rf6x-r45m-xv3w: Langflow is Missing Ownership Verification in API Key Deletion (IDOR)", "source": "ollama:qwen2.5:3b:fix", "original_id": "ghsa-639-0002"}
