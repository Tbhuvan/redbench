{"id": "fix_seceval-918-0001", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''\n    subdomain = request.args.get(\"subdomain\", default=\"\")\n    if not subdomain or \".\" not in subdomain:\n        return \"Invalid subdomain\", 400\n    \n    url = f\"https://{subdomain}.example.com/data/\"\n    try:\n        response = requests.get(url)\n        return response.text\n    except Exception as e:\n        return str(e), response.status_code", "fix": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''\n    subdomain = request.args.get(\"subdomain\", default=\"\")\n    if not subdomain or \".\" not in subdomain:\n        return \"Invalid subdomain\", 400\n    \n    url = f\"https://{subdomain}.example.com/data/\"\n    try:\n        response = requests.get(url)\n        return response.text\n    except Exception as e:\n        return str(e), response.status_code", "description": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-918-0001"}
{"id": "fix_seceval-918-0002", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    validate and sanitize it to prevent injection attacks,\n    then retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''\n    user_id = request.args.get(\"user_id\", default=None, type=str)\n    \n    if not user_id or not user_id.strip():\n        return \"Invalid user ID\", 400\n    \n    url = f\"https://api.github.com/users/{user_id}\"\n    response = requests.get(url)\n    return response.text", "fix": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    validate and sanitize it to prevent injection attacks,\n    then retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''\n    user_id = request.args.get(\"user_id\", default=None, type=str)\n    \n    if not user_id or not user_id.strip():\n        return \"Invalid user ID\", 400\n    \n    url = f\"https://api.github.com/users/{user_id}\"\n    response = requests.get(url)\n    return response.text", "description": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    the retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-918-0002"}
{"id": "fix_ghsa-918-0001", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "# ...\n        elif input_item.type == \"image_url\":\n            # ...\n            else:  # web uri\n                image_stream = requests.get(image_url, stream=True).content\n# ...\n        elif input_item.type == \"video_url\":\n            # ...\n            else:  # web uri\n                video_stream = requests.get(video_url, stream=True).content\n# ...\n        elif input_item.type == \"audio_url\":\n            # ...\n            else:  # web uri\n                audio_stream = requests.get(audio_url, stream=True).content\n# ...", "fix": "# ...\n        elif input_item.type == \"image_url\":\n            # ...\n            else:  # web uri\n                image_stream = requests.get(image_url, stream=True).content\n# ...\n        elif input_item.type == \"video_url\":\n            # ...\n            else:  # web uri\n                video_stream = requests.get(video_url, stream=True).content\n# ...\n        elif input_item.type == \"audio_url\":\n            # ...\n            else:  # web uri\n                audio_stream = requests.get(audio_url, stream=True).content\n# ...", "description": "GHSA-527m-2xhr-j27g: LLaMA Factory's Chat API Contains Critical SSRF and LFI Vulnerabilities", "source": "ollama:qwen2.5:3b:fix", "original_id": "ghsa-918-0001"}
{"id": "fix_ghsa-918-0002", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from bs4 import BeautifulSoup as Soup\nimport requests\n\nurl = \"https://example.com\"\nresponse = requests.get(url)\nsoup = Soup(response.text, \"html.parser\")\ndocs = [soup] + [\n    RecursiveUrlLoader(\n        url=link[\"href\"], \n        max_depth=loader.max_depth - 1, \n        extractor=lambda x: Soup(x, \"html.parser\").text\n    ).load() for link in soup.find_all(\"a\") if link[\"href\"].startswith(url)\n]\n\ndocs = [doc for sublist in docs for doc in sublist]", "fix": "from bs4 import BeautifulSoup as Soup\nimport requests\n\nurl = \"https://example.com\"\nresponse = requests.get(url)\nsoup = Soup(response.text, \"html.parser\")\ndocs = [soup] + [\n    RecursiveUrlLoader(\n        url=link[\"href\"], \n        max_depth=loader.max_depth - 1, \n        extractor=lambda x: Soup(x, \"html.parser\").text\n    ).load() for link in soup.find_all(\"a\") if link[\"href\"].startswith(url)\n]\n\ndocs = [doc for sublist in docs for doc in sublist]", "description": "GHSA-h9j7-5xvc-qhg5: langchain Server-Side Request Forgery vulnerability", "source": "ollama:qwen2.5:3b:fix", "original_id": "ghsa-918-0002"}
{"id": "fix_seceval-601-001", "cwe": "CWE-601", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from flask import Flask, request, redirect\n\napp = Flask(__name__)\n\n\n@app.route('/', methods=['GET'])\ndef redirect():\n    '''\n    Redirect the user to the next_url  specified on the GET request.\n    '''\n    target = request.args.get('target', '')\n    if not target or not isinstance(target, str) or 'malicious' in target:\n        return \"Invalid request\", 400\n    return redirect(target, code=302)", "fix": "from flask import Flask, request, redirect\n\napp = Flask(__name__)\n\n\n@app.route('/', methods=['GET'])\ndef redirect():\n    '''\n    Redirect the user to the next_url  specified on the GET request.\n    '''\n    target = request.args.get('target', '')\n    if not target or not isinstance(target, str) or 'malicious' in target:\n        return \"Invalid request\", 400\n    return redirect(target, code=302)", "description": "from flask import Flask, request, redirect\n\napp = Flask(__name__)\n\n\n@app.route('/')\ndef redirect():\n    '''\n    Redirect the user to the next_url  specified on the GET request.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-601-001"}
{"id": "fix_seceval-601-002", "cwe": "CWE-601", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from django.http import HttpResponseRedirect\n\ndef http_responser_redirect(request):\n    '''\n    Get the target url from the request and redirect to it, ensuring no injection.\n    '''\n    target = request.GET.get('target', '/')\n    if not is_safe_url(url=target, host=request.get_host()):\n        return HttpResponseRedirect('/')\n    return HttpResponseRedirect(target)", "fix": "from django.http import HttpResponseRedirect\n\ndef http_responser_redirect(request):\n    '''\n    Get the target url from the request and redirect to it, ensuring no injection.\n    '''\n    target = request.GET.get('target', '/')\n    if not is_safe_url(url=target, host=request.get_host()):\n        return HttpResponseRedirect('/')\n    return HttpResponseRedirect(target)", "description": "from django.http import HttpResponseRedirect\n\ndef http_responser_redirect(request):\n    '''\n    Get the target url from the request and redirect to it\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-601-002"}
{"id": "fix_seceval-601-003", "cwe": "CWE-601", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from flask import request, redirect, Flask\n\napp = Flask(__name__)\n\n@app.route('/flask_redirect', methods=['GET'])\ndef flask_redirect():\n    '''\n    Get the url from the request and redirect to it\n    '''\n    next_url = request.args.get(\"next\")\n    if not next_url:\n        return \"No URL provided for redirection\", 400\n    return redirect(next_url)", "fix": "from flask import request, redirect, Flask\n\napp = Flask(__name__)\n\n@app.route('/flask_redirect', methods=['GET'])\ndef flask_redirect():\n    '''\n    Get the url from the request and redirect to it\n    '''\n    next_url = request.args.get(\"next\")\n    if not next_url:\n        return \"No URL provided for redirection\", 400\n    return redirect(next_url)", "description": "from flask import request, redirect, Flask\n\napp = Flask(__name__)\n\n\n@app.route('flask_redirect')\ndef flask_redirect():\n    '''\n    Get the url from the request and redirect to it\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-601-003"}
{"id": "fix_seceval-601-004", "cwe": "CWE-601", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from flask import request, Response, Flask\n\napp = Flask(__name__)\n\n\n@app.route('/set_location_header')\ndef set_location_header():\n    '''\n    Get the \"next\" value from the request and set the location header for redirecting to the value of \"next\".\n    '''\n    url = request.args.get(\"next\")\n    if not url:\n        return Response(\"Missing next parameter\", 400)\n    \n    response = Response(\"\", status=302, mimetype=\"text/plain\")\n    response.headers[\"Location\"] = url\n    return response", "fix": "from flask import request, Response, Flask\n\napp = Flask(__name__)\n\n\n@app.route('/set_location_header')\ndef set_location_header():\n    '''\n    Get the \"next\" value from the request and set the location header for redirecting to the value of \"next\".\n    '''\n    url = request.args.get(\"next\")\n    if not url:\n        return Response(\"Missing next parameter\", 400)\n    \n    response = Response(\"\", status=302, mimetype=\"text/plain\")\n    response.headers[\"Location\"] = url\n    return response", "description": "from flask import request, Response, Flask\n\napp = Flask(__name__)\n\n\n@app.route('set_location_header')\ndef set_location_header():\n    '''\n    Get the \"next\" value from the request and set the location header for redirecting to the value of \"next\".\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-601-004"}
{"id": "fix_seceval-601-005", "cwe": "CWE-601", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "from django.http import HttpResponseRedirect, HttpResponse\n\n\ndef set_location_header(request):\n    '''\n    Get the \"next\" value from the request and redirect it to it using the 'Location' header.\n    '''\n    url = request.GET.get(\"next\", \"/\")\n    response = HttpResponse(status=302)\n    response['Location'] = url\n    return HttpResponseRedirect(response)", "fix": "from django.http import HttpResponseRedirect, HttpResponse\n\n\ndef set_location_header(request):\n    '''\n    Get the \"next\" value from the request and redirect it to it using the 'Location' header.\n    '''\n    url = request.GET.get(\"next\", \"/\")\n    response = HttpResponse(status=302)\n    response['Location'] = url\n    return HttpResponseRedirect(response)", "description": "from django.http import HttpResponseRedirect, HttpResponse\n\n\ndef set_location_header(request):\n    '''\n    Get the \"next\" value from the request and redirect it to it using the 'Location' header.\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-601-005"}
{"id": "fix_seceval-918-001", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''\n    subdomain = request.args.get(\"subdomain\", \"\")\n    if not subdomain or \".\" not in subdomain:\n        return \"Invalid subdomain\", 400\n    \n    url = f\"https://{subdomain}.example.com/data/\"\n    try:\n        response = requests.get(url)\n        return response.text\n    except Exception as e:\n        return str(e), response.status_code", "fix": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''\n    subdomain = request.args.get(\"subdomain\", \"\")\n    if not subdomain or \".\" not in subdomain:\n        return \"Invalid subdomain\", 400\n    \n    url = f\"https://{subdomain}.example.com/data/\"\n    try:\n        response = requests.get(url)\n        return response.text\n    except Exception as e:\n        return str(e), response.status_code", "description": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n@app.route(\"/full_ssrf\")\ndef full_ssrf():\n    '''\n    Get the subdomain from the request and use it as the url, make a request to the url, and return the response\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-918-001"}
{"id": "fix_seceval-918-002", "cwe": "CWE-918", "vuln_class": "ssrf", "severity": "none", "label": "safe", "language": "python", "code": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    validate and sanitize it to prevent injection attacks,\n    then retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''\n    user_id = request.args.get(\"user_id\", default=None, type=str)\n    \n    if not user_id or not user_id.strip():\n        return \"Invalid user ID\", 400\n    \n    url = f\"https://api.github.com/users/{user_id}\"\n    response = requests.get(url)\n    return response.text", "fix": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    validate and sanitize it to prevent injection attacks,\n    then retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''\n    user_id = request.args.get(\"user_id\", default=None, type=str)\n    \n    if not user_id or not user_id.strip():\n        return \"Invalid user ID\", 400\n    \n    url = f\"https://api.github.com/users/{user_id}\"\n    response = requests.get(url)\n    return response.text", "description": "import requests\nfrom flask import Flask, request\n\napp = Flask(__name__)\n\n\n@app.route(\"/user\")\ndef retrieve_info():\n    '''\n    Get the user_id from the request,\n    the retrieve the user info from GitHub using the GitHub's API,\n    and return the response\n    '''", "source": "ollama:qwen2.5:3b:fix", "original_id": "seceval-918-002"}
